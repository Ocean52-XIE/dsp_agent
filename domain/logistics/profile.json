{
  "schema_version": 1,
  "profile_id": "logistics",
  "display_name": "物流平台",
  "language": "zh-CN",
  "sources": {
    "wiki": {
      "root": "wiki",
      "glob": "**/*.md"
    },
    "code": {
      "roots": [
        "codes"
      ],
      "include_ext": [
        ".py",
        ".js",
        ".jsx",
        ".ts",
        ".tsx",
        ".go",
        ".java",
        ".sql"
      ],
      "exclude_dirs": [
        ".git",
        "__pycache__",
        ".pytest_cache",
        "node_modules",
        ".venv",
        "venv",
        "dist",
        "build",
        "target"
      ]
    },
    "cases": {
      "path": "eval/datasets/logistics_answer_eval_hybrid.jsonl"
    }
  },
  "domain_gate": {
    "threshold": 0.5,
    "weak_in_scope_min_score": 0.62,
    "weak_code_hint_min_score": 0.58,
    "history_memory_bonus": 0.18,
    "offtopic_penalty": 0.45,
    "short_query_penalty": 0.25,
    "short_query_max_len": 4,
    "code_hint_regex": "[A-Za-z_][A-Za-z0-9_]{2,}\\s*(\\(|\\.py\\b|/)",
    "laugh_like_regex": "^[哈呵嘿啊嗯哦嗨~\\s!！?？,，。…]+$",
    "domain_terms": [
      "物流",
      "运单",
      "揽收",
      "干线",
      "末端",
      "派送",
      "签收",
      "时效",
      "路由",
      "配载",
      "仓储",
      "波次",
      "库存",
      "出库",
      "入库",
      "eta",
      "tms",
      "wms",
      "调度",
      "履约",
      "轨迹",
      "tracking",
      "pod"
    ],
    "small_talk_exact": [
      "哈",
      "哈哈",
      "哈哈哈",
      "呵呵",
      "嘿嘿",
      "嗯",
      "哦",
      "嗨",
      "在吗",
      "你好",
      "hi",
      "hello",
      "ok",
      "thanks",
      "谢谢"
    ],
    "small_talk_substr": [
      "笑死",
      "晚安",
      "早安",
      "早上好",
      "中午好",
      "晚上好"
    ],
    "offtopic_terms": [
      "天气",
      "股价",
      "股票",
      "基金",
      "彩票",
      "电影",
      "翻译",
      "作文",
      "旅游",
      "菜谱",
      "八卦",
      "星座"
    ]
  },
  "routing": {
    "default_module": "logistics-orchestrator",
    "module_infer_strategy": "keyword_then_symbol",
    "prefer_symbol_match": true
  },
  "modules": [
    {
      "name": "logistics-orchestrator",
      "hint": "物流主链路编排",
      "route_priority": 100,
      "keywords": [
        "物流平台",
        "主链路",
        "流程",
        "编排",
        "全局",
        "架构"
      ],
      "aliases": [
        "物流主链路",
        "物流架构流程"
      ]
    },
    {
      "name": "order-fulfillment",
      "hint": "订单履约与分单",
      "route_priority": 20,
      "keywords": [
        "履约",
        "分单",
        "订单状态",
        "sla"
      ],
      "aliases": [
        "订单履约",
        "分单策略"
      ]
    },
    {
      "name": "route-planner",
      "hint": "路径规划与ETA",
      "route_priority": 10,
      "keywords": [
        "路由",
        "路径",
        "eta",
        "时效",
        "最短路径"
      ],
      "symbol_keywords": [
        "plan_route",
        "calculate_eta"
      ],
      "aliases": [
        "路径规划",
        "时效预估"
      ]
    },
    {
      "name": "dispatch-optimizer",
      "hint": "运力分配与派单",
      "route_priority": 15,
      "keywords": [
        "派单",
        "运力",
        "调度",
        "配载",
        "骑手",
        "司机"
      ],
      "symbol_keywords": [
        "assign_courier",
        "optimize_dispatch"
      ],
      "aliases": [
        "派单优化",
        "调度策略"
      ]
    },
    {
      "name": "warehouse-fulfillment",
      "hint": "仓内作业与波次",
      "route_priority": 30,
      "keywords": [
        "波次",
        "拣货",
        "库位",
        "出库",
        "入库",
        "库存"
      ],
      "symbol_keywords": [
        "allocate_wave",
        "release_pick_task"
      ],
      "aliases": [
        "仓储履约",
        "仓内作业"
      ]
    },
    {
      "name": "tracking-events",
      "hint": "轨迹回传与异常跟踪",
      "route_priority": 25,
      "keywords": [
        "轨迹",
        "tracking",
        "回传",
        "丢件",
        "延误"
      ],
      "symbol_keywords": [
        "update_tracking_event",
        "mark_exception"
      ],
      "aliases": [
        "轨迹回传",
        "异常跟踪"
      ]
    }
  ],
