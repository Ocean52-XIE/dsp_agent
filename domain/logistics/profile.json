    "query_templates": []
  },
  "retrieval": {
    "presets": {
      "hybrid": {
        "wiki_top_k": 4,
        "code_top_k": 4,
        "case_top_k": 2,
        "final_top_k": 6
      },
      "wiki_first": {
        "wiki_top_k": 6,
        "code_top_k": 2,
        "case_top_k": 2,
        "final_top_k": 6
      },
      "code_first": {
        "wiki_top_k": 2,
        "code_top_k": 7,
        "case_top_k": 1,
        "final_top_k": 6
      }
    },
    "source_weights": {
      "wiki": 1.0,
      "code": 1.0,
      "case": 0.7
    },
    "max_per_source": {
      "wiki": 4,
      "code": 4,
      "case": 2
    },
    "enable_wiki": true,
    "enable_code": true,
    "enable_cases": false
  },
  "answering": {
    "calibration_terms": [
      "时效校准",
      "eta",
      "履约率",
      "准时率"
    ],
    "bid_terms": [],
    "bid_entry_terms": [],
    "default_entry_symbol": ""
  },
  "code_generation": {
    "file_templates": [
      "services/logistics/{module_name}/handler.py",
      "tests/logistics/{module_name}/test_handler.py"
    ]
  },
  "prompts": {
    "qa_system": "你是物流平台知识问答助手，请严格遵守：\\n1. 只能基于提供的检索证据回答，不补充证据外事实。\\n2. 无法形成结论时输出“当前证据不足”。\\n3. 输出中文，结构化为：结论 -> 依据。\\n4. 若问题要求函数/文件定位且有 code 证据，至少给 1 个代码锚点（路径+符号，尽量带行号）。\\n5. 不输出与问题无关内容。",
    "issue_system_path": "prompts/issue_system.md"
  },
  "eval": {
    "retrieval_dataset": "eval/datasets/logistics_retrieval_eval.jsonl",
    "code_retrieval_dataset": "eval/datasets/logistics_code_retrieval_eval.jsonl",
    "answer_dataset": "eval/datasets/logistics_answer_eval.jsonl",
    "hybrid_answer_dataset": "eval/datasets/logistics_answer_eval_hybrid.jsonl",
    "issue_analysis_dataset": "eval/datasets/logistics_issue_analysis_eval.jsonl"
  }
