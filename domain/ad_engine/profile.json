  "retrieval": {
    "presets": {
      "hybrid": {
        "wiki_top_k": 4,
        "code_top_k": 4,
        "case_top_k": 2,
        "final_top_k": 6
      },
      "wiki_first": {
        "wiki_top_k": 6,
        "code_top_k": 2,
        "case_top_k": 1,
        "final_top_k": 6
      },
      "code_first": {
        "wiki_top_k": 2,
        "code_top_k": 7,
        "case_top_k": 1,
        "final_top_k": 6
      }
    },
    "source_weights": {
      "wiki": 1.0,
      "code": 1.0,
      "case": 0.6
    },
    "max_per_source": {
      "wiki": 4,
      "code": 4,
      "case": 1
    },
    "enable_wiki": true,
    "enable_code": true,
    "enable_cases": false
  },
  "fusion": {
    "intent_source_bias": {
      "code_location": {
        "code": 0.25,
        "wiki": -0.1,
        "case": 0.0
      },
      "wiki_first": {
        "wiki": 0.15,
        "code": -0.05,
        "case": 0.0
      }
    }
  },
