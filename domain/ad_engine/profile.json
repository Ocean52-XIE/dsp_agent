    "code_retrieval_dataset": "eval/datasets/ad_engine_code_retrieval_eval.jsonl",
    "answer_dataset": "eval/datasets/ad_engine_answer_eval.jsonl",
    "hybrid_answer_dataset": "eval/datasets/ad_engine_answer_eval_hybrid.jsonl"
  }
